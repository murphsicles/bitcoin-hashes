/// SHA-512 hash implementation for Zeta
/// Implements FIPS PUB 180-4 SHA-512

const K512: [u64; 80] = [
    0x428a2f98d728ae22, 0x7137449123ef65cd, 0xb5c0fbcfec4d3b2f, 0xe9b5dba58189dbbc,
    0x3956c25bf348b538, 0x59f111f1b605d019, 0x923f82a4af194f9b, 0xab1c5ed5da6d8118,
    0xd807aa98a3030242, 0x12835b0145706fbe, 0x243185be4ee4b28c, 0x550c7dc3d5ffb4e2,
    0x72be5d74f27b896f, 0x80deb1fe3b1696b1, 0x9bdc06a725c71235, 0xc19bf174cf692694,
    0xe49b69c19ef14ad2, 0xefbe4786384f25e3, 0x0fc19dc68b8cd5b5, 0x240ca1cc77ac9c65,
    0x2de92c6f592b0275, 0x4a7484aa6ea6e483, 0x5cb0a9dcbd41fbd4, 0x76f988da831153b5,
    0x983e5152ee66dfab, 0xa831c66d2db43210, 0xb00327c898fb213f, 0xbf597fc7beef0ee4,
    0xc6e00bf33da88fc2, 0xd5a79147930aa725, 0x06ca6351e003826f, 0x142929670a0e6e70,
    0x27b70a8546d22ffc, 0x2e1b21385c26c926, 0x4d2c6dfc5ac42aed, 0x53380d139d95b3df,
    0x650a73548baf63de, 0x766a0abb3c77b2a8, 0x81c2c92e47edaee6, 0x92722c851482353b,
    0xa2bfe8a14cf10364, 0xa81a664bbc423001, 0xc24b8b70d0f89791, 0xc76c51a30654be30,
    0xd192e819d6ef5218, 0xd69906245565a910, 0xf40e35855771202a, 0x106aa07032bbd1b8,
    0x19a4c116b8d2d0c8, 0x1e376c085141ab53, 0x2748774cdf8eeb99, 0x34b0bcb5e19b48a8,
    0x391c0cb3c5c95a63, 0x4ed8aa4ae3418acb, 0x5b9cca4f7763e373, 0x682e6ff3d6b2b8a3,
    0x748f82ee5defb2fc, 0x78a5636f43172f60, 0x84c87814a1f0ab72, 0x8cc702081a6439ec,
    0x90befffa23631e28, 0xa4506cebde82bde9, 0xbef9a3f7b2c67915, 0xc67178f2e372532b,
    0xca273eceea26619c, 0xd186b8c721c0c207, 0xeada7dd6cde0eb1e, 0xf57d4f7fee6ed178,
    0x06f067aa72176fba, 0x0a637dc5a2c898a6, 0x113f9804bef90dae, 0x1b710b35131c471b,
    0x28db77f523047d84, 0x32caab7b40c72493, 0x3c9ebe0a15c9bebc, 0x431d67c49c100d4c,
    0x4cc5d4becb3e42b6, 0x597f299cfc657e2a, 0x5fcb6fab3ad6faec, 0x6c44198c4a475817,
];

fn ch64(x: u64, y: u64, z: u64) -> u64 { (x & y) ^ ((!x) & z) }
fn maj64(x: u64, y: u64, z: u64) -> u64 { (x & y) ^ (x & z) ^ (y & z) }
fn sigma0_64(x: u64) -> u64 { x.rotr(28) ^ x.rotr(34) ^ x.rotr(39) }
fn sigma1_64(x: u64) -> u64 { x.rotr(14) ^ x.rotr(18) ^ x.rotr(41) }
fn gamma0_64(x: u64) -> u64 { x.rotr(1) ^ x.rotr(8) ^ (x >> 7) }
fn gamma1_64(x: u64) -> u64 { x.rotr(19) ^ x.rotr(61) ^ (x >> 6) }

pub struct Sha512 {
    inner: [u8; 64],
}

impl Sha512 {
    pub fn new() -> Self {
        Self { inner: [0u8; 64] }
    }

    /// Compute SHA-512 hash of data
    pub fn hash(data: &[u8]) -> Self {
        let mut state: [u64; 8] = [
            0x6a09e667f3bcc908, 0xbb67ae8584caa73b,
            0x3c6ef372fe94f82b, 0xa54ff53a5f1d36f1,
            0x510e527fade682d1, 0x9b05688c2b3e6c1f,
            0x1f83d9abfb41bd6b, 0x5be0cd19137e2179,
        ];

        let msg = pad_message_512(data);
        let n = msg.len() / 128;

        for block_idx in 0..n {
            let offset = block_idx * 128;
            let mut w: [u64; 80] = [0u64; 80];

            for t in 0..16 {
                let i = offset + t * 8;
                w[t] = (msg[i] as u64) << 56
                    | (msg[i + 1] as u64) << 48
                    | (msg[i + 2] as u64) << 40
                    | (msg[i + 3] as u64) << 32
                    | (msg[i + 4] as u64) << 24
                    | (msg[i + 5] as u64) << 16
                    | (msg[i + 6] as u64) << 8
                    | (msg[i + 7] as u64);
            }

            for t in 16..80 {
                w[t] = gamma1_64(w[t - 2])
                    .wadd(w[t - 7])
                    .wadd(gamma0_64(w[t - 15]))
                    .wadd(w[t - 16]);
            }

            let (mut a, mut b, mut c, mut d) = (state[0], state[1], state[2], state[3]);
            let (mut e, mut f, mut g, mut h) = (state[4], state[5], state[6], state[7]);

            for t in 0..80 {
                let t1 = h
                    .wadd(sigma1_64(e))
                    .wadd(ch64(e, f, g))
                    .wadd(K512[t])
                    .wadd(w[t]);
                let t2 = sigma0_64(a).wadd(maj64(a, b, c));
                h = g;
                g = f;
                f = e;
                e = d.wadd(t1);
                d = c;
                c = b;
                b = a;
                a = t1.wadd(t2);
            }

            state[0] = state[0].wadd(a);
            state[1] = state[1].wadd(b);
            state[2] = state[2].wadd(c);
            state[3] = state[3].wadd(d);
            state[4] = state[4].wadd(e);
            state[5] = state[5].wadd(f);
            state[6] = state[6].wadd(g);
            state[7] = state[7].wadd(h);
        }

        let mut result = [0u8; 64];
        for i in 0..8 {
            let offset = i * 8;
            result[offset]     = (state[i] >> 56) as u8;
            result[offset + 1] = (state[i] >> 48) as u8;
            result[offset + 2] = (state[i] >> 40) as u8;
            result[offset + 3] = (state[i] >> 32) as u8;
            result[offset + 4] = (state[i] >> 24) as u8;
            result[offset + 5] = (state[i] >> 16) as u8;
            result[offset + 6] = (state[i] >> 8) as u8;
            result[offset + 7] = state[i] as u8;
        }

        Self { inner: result }
    }

    pub fn from_slice(bytes: &[u8]) -> Result<Self> {
        if bytes.len() != 64 {
            return Err("Sha512 must be exactly 64 bytes");
        }
        let mut inner = [0u8; 64];
        inner.copy_from_slice(bytes);
        Ok(Self { inner })
    }

    pub fn to_byte_array(self) -> [u8; 64] {
        self.inner
    }
}

impl Hash for Sha512 {
    fn hash(data: &[u8]) -> Self {
        Sha512::hash(data)
    }

    fn from_slice(bytes: &[u8]) -> Result<Self> {
        Sha512::from_slice(bytes)
    }

    fn to_byte_array(self) -> [u8] {
        self.inner[..]
    }
}

fn pad_message_512(data: &[u8]) -> Vec<u8> {
    let len_bits = (data.len() as u128) * 8;
    let mod_val = (data.len() * 8) % 1024;
    let pad_len = if mod_val < 896 {
        (896 - mod_val) / 8
    } else {
        (1024 - mod_val + 896) / 8
    };

    let total_bytes = data.len() + pad_len + 16;
    let mut msg = Vec::with_capacity(total_bytes);
    msg.extend_from_slice(data);
    msg.push(0x80);

    let zero_bytes = pad_len - 1;
    for _ in 0..zero_bytes {
        msg.push(0x00);
    }

    // Append length in bits as big-endian 128-bit
    for i in 0..16 {
        let shift = (15 - i) * 8;
        msg.push((len_bits >> shift) as u8);
    }

    msg
}
